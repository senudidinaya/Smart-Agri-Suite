# Optional full override. If set, this value is used directly.
# Examples:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000/api/v1
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.9:8000/api/v1
EXPO_PUBLIC_API_BASE_URL=

# Android quick switch when EXPO_PUBLIC_API_BASE_URL is empty:
# - emulator: uses 10.0.2.2
# - device: uses EXPO_PUBLIC_DEV_MACHINE_IP
EXPO_PUBLIC_ANDROID_TARGET=device

# Host machine LAN IP for physical devices.
EXPO_PUBLIC_DEV_MACHINE_IP=192.168.1.9
