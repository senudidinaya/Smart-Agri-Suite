{
  "expo": {
    "name": "Idle Land Mobilization System",
    "slug": "idle-land-mobilization",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "idleland",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.smartsgri.idleland",
      "versionCode": 1
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartsgri.idleland"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}