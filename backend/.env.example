# =============================================================================
# Smart Agri-Suite - Cultivator Intent Module
# Backend Environment Configuration
# =============================================================================

# Application Settings
APP_NAME="Smart Agri-Suite API"
APP_VERSION="2.0.0"
DEBUG=false
ENVIRONMENT=development

# Server Settings
HOST=0.0.0.0
PORT=8001

# CORS Settings (comma-separated list)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:19006"]

# MongoDB Settings
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=smartagri

# Authentication
AUTH_SECRET=your_secret_key_change_in_production

# =============================================================================
# Agora RTC Settings (Required for Voice Calling)
# Get credentials from https://console.agora.io/
# =============================================================================
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# Agora RESTful API credentials for Cloud Recording (optional)
# Get from: Agora Console -> RESTful API -> Create New Secret
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# Cloud Recording Storage (optional - for server-side recording)
# Vendor codes: 0=Agora Cloud, 1=AWS S3, 2=Azure, 3=GCP, 5=Alibaba, 6=Tencent
AGORA_RECORDING_VENDOR=0
AGORA_RECORDING_BUCKET=
AGORA_RECORDING_ACCESS_KEY=
AGORA_RECORDING_SECRET_KEY=
AGORA_RECORDING_REGION=0

# =============================================================================
# ML Model Settings
# =============================================================================
MODEL_PATH=models/intent_classifier.pt
MODEL_DEVICE=cpu

# Audio Processing
MAX_AUDIO_DURATION_SECONDS=30.0
SUPPORTED_AUDIO_FORMATS=["wav","mp3","ogg","flac","m4a"]
SAMPLE_RATE=16000

# Logging
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true
